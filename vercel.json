{
  "version": 3,
  "functions": {
    "main.py": {
      "runtime": "vercel-python"
    }
  },
  "routes": [
    {
      "src": "/convertir",
      "dest": "main.py"
    },
    {
      "src": "/suma-binaria",
      "dest": "main.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
