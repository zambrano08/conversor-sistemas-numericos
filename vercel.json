{
  "rewrites": [
    { "source": "/(index.html)?", "destination": "/frontend/index.html" },
    { "source": "/static/(.*)", "destination": "/frontend/$1" },
    { "source": "/(.*)", "destination": "/main.py" }
  ],
  "functions": {
    "main.py": {
      "runtime": "vercel-python@0.6.0"
    }
  }
}